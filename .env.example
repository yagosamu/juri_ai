# JuriAI local environment example
# Copy to .env for local development. Never commit real secrets.

# Django core
SECRET_KEY=change-me-in-prod
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# Data directory for generated runtime files. Use an absolute path in production.
DATA_DIR=.

# PostgreSQL. Prefer DATABASE_URL in production.
DATABASE_URL=
DB_NAME=juriai_db
DB_USER=postgres
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432

# Fernet key used by encrypted fields such as ConfiguracaoWhatsApp.api_key.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=generate-a-fernet-key

# AI providers
OPENAI_API_KEY=your-openai-api-key-here

# Langfuse observability. Disabled by default; enable only after PII masking is verified.
LANGFUSE_ENABLED=False
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Current Langfuse SDK docs use LANGFUSE_BASE_URL.
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# DataJud/CNJ API key. Current code still has a fallback literal; use this when moving it to env.
DATAJUD_API_KEY=your-datajud-api-key-here

# Google Calendar OAuth
GOOGLE_CLIENT_SECRET_PATH=client_secret.json
GOOGLE_CLIENT_SECRET_JSON=

# Agno/LanceDB runtime storage
LANCEDB_URI=./lancedb
AGNO_MEMORY_DB_FILE=./agno_memory.sqlite3

# Email alerts. Console backend is safest for local development.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=JuriAI <noreply@example.com>

# Optional hardening knobs for future deployment changes
ADMIN_URL=admin/
EVOLUTION_WEBHOOK_SECRET=change-me-in-prod
